# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=server_provision
# Prototype-only: set MONGO_MOCK=1 to use an in-memory mongomock backend
# (no Docker needed). State is lost on restart.
# MONGO_MOCK=1

# Form API (Flask). Also serves the built SPA in production and reverse
# proxies /copilotkit/* to COPILOTKIT_RUNTIME_URL.
FORM_API_HOST=0.0.0.0
FORM_API_PORT=5001
FORM_API_URL=http://localhost:5001
# Defaults to http://localhost:5003/copilotkit (bare-metal); docker-compose
# overrides to http://runtime:5003/copilotkit.
# COPILOTKIT_RUNTIME_URL=http://localhost:5003/copilotkit

# Agent (FastAPI + LangGraph)
AGENT_HOST=0.0.0.0
AGENT_PORT=5002

# LLM (required for the agent service; factory fails fast if unset)
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# LLM_API_KEY=sk-ant-...
